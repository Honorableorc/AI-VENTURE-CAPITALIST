# Copy to .env and fill in. Nothing here is required to run the stub graph.

# ---- LLM -------------------------------------------------------------
# LLM_PROVIDER: ollama | anthropic | openai
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.3
OLLAMA_BASE_URL=http://localhost:11434

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Tools -----------------------------------------------------------
# TAVILY_API_KEY=
# GITHUB_TOKEN=

# ---- Runtime ---------------------------------------------------------
PARALLEL_AGENTS=true
HUMAN_APPROVAL=false
REPORTS_DIR=reports
MEMORY_DB=memory/venture.sqlite
